<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="fitlib.db" />
        <include domain="database" path="fitlib.db-wal" />
        <include domain="database" path="fitlib.db-shm" />
        <include domain="file" path="custom_exercises_snapshot.json" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="fitlib.db" />
        <include domain="database" path="fitlib.db-wal" />
        <include domain="database" path="fitlib.db-shm" />
        <include domain="file" path="custom_exercises_snapshot.json" />
    </device-transfer>
</data-extraction-rules>
